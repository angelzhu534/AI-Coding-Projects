/* ══════════════════════════════════════════════════════
   CATEGORIZE  (OSM tags win first, no name-guessing)
══════════════════════════════════════════════════════ */
function categorize(tags) {
  const a=tags.amenity||'', s=tags.shop||'', l=tags.leisure||'', t=tags.tourism||'', name=(tags.name||'').toLowerCase();
  // Tag-based (authoritative) — checked before any name inference
  if (['restaurant','fast_food','food_court','ice_cream','juice_bar'].includes(a)) return 'food';
  if (['bakery','deli','seafood','butcher'].includes(s)) return 'food';
  if (['cafe','coffee_shop'].includes(a) || ['tea','coffee'].includes(s)) return 'cafe';
  if (['bar','pub','nightclub','brewery','biergarten','taproom'].includes(a)) return 'bar';
  if (s==='florist' || s==='garden_centre') return 'florist';
  if (s&&!['tea','coffee','bakery','deli','seafood','supermarket','convenience','grocery','wine','beer','yes'].includes(s)) return 'shop';
  if (['supermarket','convenience','grocery','wine','beer','alcohol'].includes(s)) return 'shop';
  if (['park','garden','nature_reserve','pitch','playground'].includes(l)||tags.natural) return 'nature';
  if (['museum','gallery','attraction','artwork','viewpoint'].includes(t)||tags.historic||['arts_centre','theatre','cinema'].includes(a)) return 'culture';
  // Name fallback (boba only — narrow and reliable)
  if (name.includes('boba')||name.includes('bubble tea')||name.includes('tapioca')) return 'cafe';
  return 'other';
}

function getLabel(tags, cat) {
  const a=tags.amenity||'', s=tags.shop||'';
  if (a==='restaurant') return tags.cuisine ? ucfirst(tags.cuisine.split(';')[0])+' Restaurant' : 'Restaurant';
  if (a==='fast_food')  return 'Fast Food';
  if (a==='cafe')       return 'Café';
  if (a==='bar')        return 'Bar';
  if (a==='pub')        return 'Pub';
  if (a==='brewery')    return 'Brewery';
  if (a==='nightclub')  return 'Nightclub';
  if (a==='ice_cream')  return 'Ice Cream';
  if (s==='florist')    return 'Florist';
  if (s==='bakery')     return 'Bakery';
  if (['books','bookshop'].includes(s)) return 'Bookshop';
  if (s==='ceramics')   return 'Ceramics';
  if (s==='art')        return 'Art Gallery';
  return CATS[cat]?.label || 'Place';
}

function ucfirst(s) { return s?s[0].toUpperCase()+s.slice(1):''; }

/* ══════════════════════════════════════════════════════
   MARKERS
══════════════════════════════════════════════════════ */
function makeIconHTML(catKey, isSelected, isDone) {
  const cat = CATS[catKey]||CATS.other;
  return `<div class="m-icon${isSelected?' sel':''}${isDone?' done':''}" style="background:${cat.color}">
    ${isDone?'<div class="m-chk">✓</div>':''}
    <span>${cat.emoji}</span>
  </div>`;
}

function makeIcon(place) {
  const isSelected = selectedId===place.id;
  const size = isSelected ? 40 : 32;
  return L.divIcon({
    html: makeIconHTML(place.cat, isSelected, !!checked[place.id]),
    className: 'icon-wrap',
    iconSize: [size,size], iconAnchor: [size/2,size/2], tooltipAnchor:[size/2+4,0]
  });
}

function createMarker(place, delayMs=0) {
  const m = L.marker([place.lat,place.lng], { icon:makeIcon(place), zIndexOffset:0, riseOnHover:true });
  m.on('click', e => { L.DomEvent.stopPropagation(e); showDetail(place); });
  // Stagger pop-in animation
  if (delayMs > 0) {
    setTimeout(() => m.addTo(map), delayMs);
  } else {
    m.addTo(map);
  }
  markerMap[place.id] = m;
}

function refreshMarkers() {
  allPlaces.forEach(p => {
    const m = markerMap[p.id]; if(!m) return;
    const visible = activeFilter==='all' || activeFilter===p.cat;
    const isSelected = selectedId===p.id;
    if (visible) {
      if (!map.hasLayer(m)) m.addTo(map);
      m.setIcon(makeIcon(p));
      m.setZIndexOffset(isSelected ? 1000 : 0);
      if (isSelected) {
        if (!m.getTooltip()) m.bindTooltip(p.name,{permanent:true,direction:'right',className:'lbl',offset:[18,0]});
        m.openTooltip();
      } else {
        if (m.getTooltip()) m.unbindTooltip();
      }
    } else {
      if (map.hasLayer(m)) map.removeLayer(m);
    }
  });
}

/* ══════════════════════════════════════════════════════
   PLACE MANAGEMENT
══════════════════════════════════════════════════════ */
function getNeighborhood(lat, lng) {
  for (const [key, nb] of Object.entries(NB_BOUNDS)) {
    if (lat>=nb.s && lat<=nb.n && lng>=nb.w && lng<=nb.e) return key;
  }
  return 'dogpatch';
}

function addPlace(data, delayMs=0) {
  data.neighborhood = getNeighborhood(data.lat, data.lng);
  allPlaces.push(data);
  createMarker(data, delayMs);
}

/* ══════════════════════════════════════════════════════
   DETAIL SHEET
══════════════════════════════════════════════════════ */
function showDetail(place) {
  selectedId = place.id;
  currentDetailId = place.id;
  refreshMarkers();
  map.panTo([place.lat,place.lng],{animate:true,duration:.4});

  const cat = CATS[place.cat]||CATS.other;
  const isDone = !!checked[place.id];
  const t = place.tags||{};

  let photoHTML = '';
  if (place.getPhoto) { const u=place.getPhoto(); if(u) photoHTML=`<img class="d-photo" src="${u}" alt="${place.name}" loading="lazy" onerror="this.style.display='none'">`; }

  let ratingHTML = '';
  if (place.rating) {
    const pct=(place.rating/5*100).toFixed(1);
    ratingHTML=`<div class="d-rating"><div class="d-stars-wrap"><div class="d-stars-empty">★★★★★</div><div class="d-stars-full" style="width:${pct}%">★★★★★</div></div><span class="d-rating-num">${place.rating.toFixed(1)}</span>${place.ratingN?`<span class="d-rating-ct">(${place.ratingN.toLocaleString()})</span>`:''}</div>`;
  }

  let openHTML = '';
  if (place.isOpen!==null) openHTML=`<div class="d-open ${place.isOpen?'yes':'no'}"><div class="d-dot"></div>${place.isOpen?'Open now':'Closed now'}</div>`;

  let hoursHTML='';
  if (place.hours?.length) {
    const hid='h'+place.id.replace(/\W/g,'');
    hoursHTML=`<span class="d-hours-toggle" onclick="document.getElementById('${hid}').classList.toggle('open')">See hours ▾</span><div class="d-hours-list" id="${hid}">${place.hours.map(h=>`<div class="d-hour-row">${h}</div>`).join('')}</div>`;
  }

  let meta='';
  if (t.cuisine)   meta+=row('🍴',ucfirst(t.cuisine.replace(/;/g,', ')));
  if (place.phone) meta+=row('📞',`<a href="tel:${place.phone}">${place.phone}</a>`);
  if (place.website) meta+=row('🌐',`<a href="${place.website}" target="_blank">${place.website.replace(/https?:\/\//,'').split('/')[0]}</a>`);
  if (place.address) meta+=row('📍',place.address);
  if (hoursHTML)   meta+=row('🕐',`<div>${hoursHTML}</div>`);
  if (place.desc)  meta+=`<div class="d-note">${place.desc}</div>`;

  const gm=`https://www.google.com/maps/search/${encodeURIComponent(place.name+' San Francisco CA')}`;
  const savedNote = notes[place.id]||'';

  document.getElementById('detail-body').innerHTML=`
    ${photoHTML}
    <div class="d-strip" style="background:${cat.color}"></div>
    <div class="d-name">${place.name}</div>
    <span class="d-badge" style="background:${cat.color}">${cat.emoji} ${cat.label}</span>
    ${ratingHTML}${openHTML}
    ${meta?`<div class="d-meta">${meta}</div>`:''}
    <div class="d-actions">
      <button class="d-btn ${isDone?'visited':'primary'}" id="dchk" onclick="toggleCheck('${place.id}',this,event)">
        ${isDone?'✓ Visited!':'⭐ Mark visited'}
      </button>
      <a class="d-btn" href="${gm}" target="_blank" rel="noopener">🗺️ Google Maps</a>
    </div>
    <div class="d-notes-wrap">
      <span class="d-notes-label">📝 Our notes</span>
      <textarea id="d-notes-ta" placeholder="Add a memory… (saves automatically)"
        oninput="saveNote('${place.id}',this.value)">${savedNote}</textarea>
    </div>`;

  document.getElementById('detail').classList.add('open');
}

function row(icon,text){return`<div class="d-row"><span class="d-icon">${icon}</span><span>${text}</span></div>`;}
function closeDetail(){selectedId=null;currentDetailId=null;document.getElementById('detail').classList.remove('open');refreshMarkers();}

/* ══════════════════════════════════════════════════════
