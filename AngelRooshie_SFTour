══════════════════════════════════════════════════════ */
let noteTimer;
function saveNote(id, val) {
  clearTimeout(noteTimer);
  noteTimer = setTimeout(() => {
    if (val.trim()) notes[id]=val.trim(); else delete notes[id];
    try { localStorage.setItem('sfwex_notes',JSON.stringify(notes)); } catch(e){}
  }, 600);
}

/* ══════════════════════════════════════════════════════
   CHECK / CONFETTI
══════════════════════════════════════════════════════ */
function toggleCheck(id, btn, evt) {
  checked[id] = !checked[id];
  try { localStorage.setItem('sfwex_checked',JSON.stringify(checked)); } catch(e){}
  if (checked[id] && evt) spawnConfetti(evt.clientX, evt.clientY);
  if (btn) { const d=checked[id]; btn.className=`d-btn ${d?'visited':'primary'}`; btn.textContent=d?'✓ Visited!':'⭐ Mark visited'; }
  refreshMarkers(); renderCL(); updateStats();
}

function spawnConfetti(cx, cy) {
  const colors=['#e03030','#c47820','#1a8848','#1840b0','#c01870','#f4a61a','#5830c0'];
  for (let i=0;i<22;i++) {
    const el=document.createElement('div');
    el.className='confetti-p';
    const dx=(Math.random()-.5)*220, dy=-(Math.random()*160+40);
    el.style.cssText=`left:${cx}px;top:${cy}px;background:${colors[i%colors.length]};--dx:${dx}px;--dy:${dy}px;border-radius:${Math.random()>.5?'50%':'2px'};width:${6+Math.random()*6}px;height:${6+Math.random()*6}px;animation-duration:${.7+Math.random()*.4}s;animation-delay:${Math.random()*.15}s`;
    document.body.appendChild(el);
    setTimeout(()=>el.remove(),1200);
  }
}

/* ══════════════════════════════════════════════════════
   CHECKLIST
══════════════════════════════════════════════════════ */
function toggleCL(){document.getElementById('cl-panel').classList.toggle('open');}
function searchCL(q){searchQ=q.toLowerCase();renderCL();}

function renderCL() {
  const done=Object.values(checked).filter(Boolean).length;
  const total=allPlaces.length;
  const pct=total>0?Math.round(done/total*100):0;
  document.getElementById('prog-lbl').textContent=`${done} of ${total} places · ${pct}% explored`;
  document.getElementById('prog-fill').style.width=pct+'%';
  const badge=document.getElementById('cl-badge');
  badge.textContent=done; badge.className=done>0?'lit':'';
  document.getElementById('cl-cel').style.display=(total>0&&done===total)?'block':'none';

  renderNbRings();

  const grouped={};
  allPlaces.forEach(p=>{
    if (searchQ&&!p.name.toLowerCase().includes(searchQ)) return;
    if (!grouped[p.cat]) grouped[p.cat]=[];
    grouped[p.cat].push(p);
  });

  // Sort by distance if geo is active
  if (userLocation) {
    Object.values(grouped).forEach(arr=>arr.sort((a,b)=>haversine(userLocation,a)-haversine(userLocation,b)));
  }

  // Active filter category floats to top
  const keys=Object.keys(CATS);
  const ordered=activeFilter==='all'?keys:[activeFilter,...keys.filter(k=>k!==activeFilter)];
  const timeCtx=getTimeContext();

  let html='';
  ordered.forEach(key=>{
    const places=grouped[key]; if(!places?.length) return;
    const cat=CATS[key];
    const catDone=places.filter(p=>checked[p.id]).length;
    const isActive=activeFilter!=='all'&&key===activeFilter;
    const isGoodNow=timeCtx&&timeCtx.cats.includes(key);
    html+=`<div>
      <div class="cl-sec-hdr${isActive?' is-active':''}">
        <div class="cl-sec-dot" style="background:${cat.color}"></div>
        ${cat.emoji} ${cat.label}${isGoodNow?' <span style="font-size:9px;background:#f4a61a22;color:#b07000;padding:1px 5px;border-radius:5px;margin-left:3px">🕐 Good now</span>':''}
        <span class="cl-sec-count">${catDone}/${places.length}</span>
      </div>
      ${places.map(p=>{
        const dist=userLocation?`<span class="cl-dist">${formatDist(haversine(userLocation,p))}</span>`:'';
        const hasNote=!!notes[p.id];
        const stars=p.rating?`<span class="cl-stars">${'★'.repeat(Math.round(p.rating))}${'☆'.repeat(5-Math.round(p.rating))}</span> ${p.rating.toFixed(1)}`:'';
        return `<div class="cl-item${checked[p.id]?' done':''}" onclick="openFromList('${p.id}')">
          <div class="cl-box" onclick="event.stopPropagation();toggleCheck('${p.id}',null,event)">${checked[p.id]?'✓':''}</div>
          <div class="cl-info">
            <div class="cl-name">${p.name}${hasNote?'<span class="cl-note-dot" title="Has a note"></span>':''}</div>
            <div class="cl-sub">${stars||cat.label}</div>
          </div>
          ${dist}
          <span style="font-size:10px;color:var(--ink3);flex-shrink:0">›</span>
        </div>`;
      }).join('')}
    </div>`;
  });

  if (!html) html=`<div style="padding:24px 20px;text-align:center;font-family:Lora,serif;font-style:italic;color:var(--ink3)">${searchQ?`No places match "${searchQ}"`:'Loading places…'}</div>`;
  document.getElementById('cl-body').innerHTML=html;
}

function openFromList(id) {
  const place=allPlaces.find(p=>p.id===id); if(!place) return;
  document.getElementById('cl-panel').classList.remove('open');
  setTimeout(()=>{ map.setView([place.lat,place.lng],17,{animate:true}); showDetail(place); },180);
}

/* ══════════════════════════════════════════════════════
   NEIGHBORHOOD RINGS
══════════════════════════════════════════════════════ */
function renderNbRings() {
  const C=2*Math.PI*16; // circumference r=16
  const nbStats={};
  Object.keys(NB_BOUNDS).forEach(k=>nbStats[k]={total:0,done:0});
  allPlaces.forEach(p=>{ const nb=p.neighborhood; if(nbStats[nb]){nbStats[nb].total++;if(checked[p.id])nbStats[nb].done++;} });

  document.getElementById('nb-rings').innerHTML=Object.entries(NB_BOUNDS).map(([key,nb])=>{
    const {total,done}=nbStats[key]||{total:0,done:0};
    const pct=total>0?done/total:0;
    const offset=C*(1-pct);
    return `<div class="nb-ring" onclick="goAreaByKey('${key}')">
      <svg viewBox="0 0 40 40">
        <circle cx="20" cy="20" r="16" fill="none" stroke="var(--border2)" stroke-width="4"/>
        <circle cx="20" cy="20" r="16" fill="none" stroke="${nb.color}" stroke-width="4"
          stroke-dasharray="${C.toFixed(1)}" stroke-dashoffset="${offset.toFixed(1)}"
          stroke-linecap="round" transform="rotate(-90 20 20)"
          style="transition:stroke-dashoffset .6s cubic-bezier(.4,0,.2,1)"/>
        <text x="20" y="24" text-anchor="middle" font-size="9" fill="${nb.color}" font-weight="800" font-family="Nunito,sans-serif">${Math.round(pct*100)}%</text>
      </svg>
      <div class="nb-ring-label">${nb.emoji} ${nb.label}</div>
      <div class="nb-ring-count">${done}/${total}</div>
    </div>`;
  }).join('');
}

function goAreaByKey(key) {
  const a=AREAS[key]; if(!a) return;
  map.flyTo(a.center,a.zoom,{animate:true,duration:1});
  document.getElementById('cl-panel').classList.remove('open');
}

/* ══════════════════════════════════════════════════════
   GEOLOCATION
══════════════════════════════════════════════════════ */
function toggleGeo(btn) {
  if (geoWatchId!==null) {
    navigator.geolocation.clearWatch(geoWatchId);
    geoWatchId=null; userLocation=null;
    btn.classList.remove('active');
    btn.textContent='📍 Near Me';
    renderCL(); return;
  }
  if (!navigator.geolocation) { toast('⚠️ Location not available on this device'); return; }
  btn.textContent='📍 Locating…';
  navigator.geolocation.getCurrentPosition(pos=>{
    userLocation={lat:pos.coords.latitude,lng:pos.coords.longitude};
    btn.classList.add('active'); btn.textContent='📍 Near Me ✓';
    renderCL(); toast('📍 Sorted by walking distance');
    // Pan map to user location
    map.setView([userLocation.lat,userLocation.lng],15,{animate:true});
  }, err=>{
    btn.textContent='📍 Near Me';
    toast('⚠️ Location not available — check browser permissions');
  }, {enableHighAccuracy:true,timeout:8000});
}

function haversine(from, to) {
  const R=6371000;
  const φ1=from.lat*Math.PI/180, φ2=to.lat*Math.PI/180;
  const Δφ=(to.lat-from.lat)*Math.PI/180, Δλ=(to.lng-from.lng)*Math.PI/180;
  const a=Math.sin(Δφ/2)**2+Math.cos(φ1)*Math.cos(φ2)*Math.sin(Δλ/2)**2;
  return R*2*Math.atan2(Math.sqrt(a),Math.sqrt(1-a));
}

function formatDist(m) {
  if (m<100) return `${Math.round(m)}m`;
  if (m<1000) return `${Math.round(m/10)*10}m`;
  return `${(m/1000).toFixed(1)}km`;
}

/* ══════════════════════════════════════════════════════
   RANDOM ADVENTURE
══════════════════════════════════════════════════════ */
function randomAdventure() {
  const pool=allPlaces.filter(p=>!checked[p.id]&&(activeFilter==='all'||p.cat===activeFilter));
  if (!pool.length) { toast('🎉 You\'ve visited everything in this category!'); return; }
  const place=pool[Math.floor(Math.random()*pool.length)];
  map.setView([place.lat,place.lng],17,{animate:true});
  showDetail(place);
  toast(`🎲 ${place.name}`);
}

/* ══════════════════════════════════════════════════════
   TIME CONTEXT
══════════════════════════════════════════════════════ */
function getTimeContext() {
  const h=new Date().getHours();
  if (h>=6  && h<11) return {cats:['cafe','food'],      label:'☀️ Morning — cafes & brunch'};
  if (h>=11 && h<14) return {cats:['food'],              label:'🌤 Lunch time'};
  if (h>=14 && h<17) return {cats:['cafe','shop','nature','culture'], label:'☁️ Afternoon — cafes & exploring'};
  if (h>=17 && h<21) return {cats:['food','bar'],        label:'🌆 Evening — dinner & drinks'};
  if (h>=21 || h<2)  return {cats:['bar'],               label:'🌙 Night out'};
  return null;
}

function initTimeBanner() {
  const ctx=getTimeContext();
  const el=document.getElementById('time-banner');
  if (!ctx) { el.style.display='none'; return; }
  el.textContent=ctx.label;
  // Add time-dot to relevant pills
  document.querySelectorAll('.pill').forEach(p=>{
    const cat=p.dataset.cat;
    const existing=p.querySelector('.time-dot');
    if (ctx.cats.includes(cat)) { if(!existing){const d=document.createElement('span');d.className='time-dot';p.appendChild(d);} }
    else { if(existing) existing.remove(); }
  });
}

/* ══════════════════════════════════════════════════════
   FILTERS / AREA / STATS
══════════════════════════════════════════════════════ */
function setFilter(btn, key) {
  document.querySelectorAll('.pill').forEach(b=>{b.classList.remove('active');b.style.background='';b.style.borderColor='';});
  btn.classList.add('active');
  const c=PILL_COLORS[key]||'#1a4a8a';
  btn.style.background=c; btn.style.borderColor=c;
  activeFilter=key; refreshMarkers(); renderCL();
  document.getElementById('cl-body').scrollTop=0;
  const n=key==='all'?allPlaces.length:allPlaces.filter(p=>p.cat===key).length;
  toast(`${CATS[key]?.emoji||'📍'} ${n} ${key==='all'?'places':CATS[key]?.label}`);
}

function goArea(area, btn) {
  document.querySelectorAll('.ap').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  const a=AREAS[area]; if(a) map.flyTo(a.center,a.zoom,{animate:true,duration:1});
}

function updateStats() {
  const counts={};
  allPlaces.forEach(p=>counts[p.cat]=(counts[p.cat]||0)+1);
  const parts=Object.entries(counts).sort((a,b)=>b[1]-a[1]).slice(0,4).map(([k,v])=>`${CATS[k]?.emoji||'📍'} ${v}`);
  document.getElementById('stats').textContent=`${allPlaces.length} places · ${parts.join(' · ')}`;
}

/* ══════════════════════════════════════════════════════
   OVERPASS DATA
══════════════════════════════════════════════════════ */
function buildQuery(){
  return `[out:json][timeout:30];
(
  node["name"]["amenity"~"restaurant|fast_food|cafe|bar|pub|nightclub|brewery|biergarten|ice_cream|juice_bar|bubble_tea|arts_centre|theatre|cinema"](${BBOX});
  node["name"]["shop"~"florist|garden_centre|clothes|gift|jewelry|antiques|books|bookshop|art|gallery|boutique|bakery|deli|tea|coffee|wine|ceramics|furniture|vintage|records|sports|stationery|toys|electronics|bicycle|candles"](${BBOX});
  node["name"]["leisure"~"park|garden|nature_reserve|playground"](${BBOX});
  node["name"]["tourism"~"museum|gallery|attraction|artwork|viewpoint"](${BBOX});
  node["name"]["historic"](${BBOX});
  way["name"]["amenity"~"restaurant|fast_food|cafe|bar|pub|brewery|ice_cream|arts_centre"](${BBOX});
  way["name"]["shop"~"florist|bakery|ceramics|art"](${BBOX});
  way["name"]["leisure"~"park|garden|nature_reserve"](${BBOX});
  way["name"]["tourism"~"museum|gallery|attraction"](${BBOX});
);
out center;`;}

const CACHE_KEY='sfwex_osm_v5', CACHE_TTL=8*60*60*1000;

async function loadData(force=false){
  document.getElementById('refresh').classList.add('spin');
  if (!force){
    try{
      const raw=localStorage.getItem(CACHE_KEY);
      if(raw){const{ts,elems}=JSON.parse(raw);if(Date.now()-ts<CACHE_TTL){processElems(elems);document.getElementById('refresh').classList.remove('spin');return;}}
    }catch(e){}
  }
  const body='data='+encodeURIComponent(buildQuery());
  for(const ep of OVERPASS_ENDPOINTS){
    try{
      const res=await fetch(ep,{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body});
      if(!res.ok) throw new Error('HTTP '+res.status);
      const json=await res.json();
      try{localStorage.setItem(CACHE_KEY,JSON.stringify({ts:Date.now(),elems:json.elements}));}catch(e){}
      processElems(json.elements);
      hideErr();
      document.getElementById('refresh').classList.remove('spin');
      return;
    }catch(err){console.warn('Overpass endpoint failed:',ep,err.message);}
  }
  // Fallback to stale cache or supplement-only
  try{const raw=localStorage.getItem(CACHE_KEY);if(raw){processElems(JSON.parse(raw).elems);showErr('Using cached data — network issue');}}
  catch(e){processElems([]);showErr('Showing curated places only — OpenStreetMap unreachable');}
  document.getElementById('refresh').classList.remove('spin');
}

function processElems(elements){
  Object.values(markerMap).forEach(m=>{if(map.hasLayer(m))map.removeLayer(m);});
  markerMap={}; allPlaces=[];
  const seen=new Set();
  (elements||[]).forEach((el,i)=>{
    if(!el.tags?.name) return;
    let lat,lng;
    if(el.type==='node'){lat=el.lat;lng=el.lon;}
    else if(el.center){lat=el.center.lat;lng=el.center.lon;}
    else return;
    const name=el.tags.name.trim();
    const cat=categorize(el.tags);
    const key=name.toLowerCase()+'|'+cat;
    if(seen.has(key)) return; seen.add(key);
    addPlace({id:`osm-${el.type}-${el.id}`,name,lat,lng,cat,tags:el.tags,label:getLabel(el.tags,cat),rating:null,ratingN:null,isOpen:null,hours:null,phone:null,website:null,address:null,desc:null,getPhoto:null}, i*8);
  });
  // Merge supplements
  SUPPLEMENT.forEach(s=>{
    const key=s.name.toLowerCase()+'|'+s.cat;
    if(!seen.has(key)){seen.add(key);addPlace({...s,tags:{},label:CATS[s.cat]?.label||'Place',rating:null,ratingN:null,isOpen:null,hours:null,phone:null,website:null,address:null,getPhoto:null});}
  });
  allPlaces.sort((a,b)=>a.name.localeCompare(b.name));
  updateStats(); renderCL();
  showLoading(false);
  toast(`✓ ${allPlaces.length} places loaded`);
}

/* ══════════════════════════════════════════════════════
   UTILS
══════════════════════════════════════════════════════ */
function showLoading(show){const el=document.getElementById('loading');if(show){el.classList.remove('fade');el.style.display='flex';}else{el.classList.add('fade');setTimeout(()=>el.style.display='none',520);}}
function showErr(msg){const b=document.getElementById('err-banner');document.getElementById('err-msg').textContent=msg;b.style.display='flex';}
function hideErr(){document.getElementById('err-banner').style.display='none';}

let toastT;
function toast(msg){const el=document.getElementById('toast');el.textContent=msg;el.classList.add('show');clearTimeout(toastT);toastT=setTimeout(()=>el.classList.remove('show'),2600);}

/* ══════════════════════════════════════════════════════
   INIT
══════════════════════════════════════════════════════ */
initTimeBanner();
SUPPLEMENT.forEach(s=>addPlace({...s,tags:{},label:CATS[s.cat]?.label||'Place',rating:null,ratingN:null,isOpen:null,hours:null,phone:null,website:null,address:null,getPhoto:null}));
updateStats(); renderCL();
loadData();
</script>
